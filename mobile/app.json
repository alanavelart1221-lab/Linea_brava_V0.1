{
  "expo": {
    "name": "Línea Brava",
    "slug": "linea-brava",
    "scheme": "lineabrava",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0B0C0E",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0C0E"
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "mx.lineabrava.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Línea Brava usa tu ubicación para grabar el trazo de tus rutas off-road.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Línea Brava graba tu recorrido en segundo plano para que puedas seguir la ruta con la pantalla apagada.",
        "UIBackgroundModes": [
          "location"
        ]
      }
    },
    "android": {
      "package": "mx.lineabrava.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#08090A"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Línea Brava usa tu ubicación para grabar el trazo de tus rutas off-road.",
          "locationAlwaysAndWhenInUsePermission": "Línea Brava graba tu recorrido en segundo plano para que puedas seguir la ruta con la pantalla apagada.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "expo-asset",
      "expo-video",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c31ee75b-c54e-4ad3-82e4-d0c429505dfe"
      }
    },
    "owner": "avelartq1215"
  }
}
